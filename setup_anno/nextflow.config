
params {
    /* =============== I/O =============== */
    resource_dir   = './cavalier_refdata'
    config_out     = null               // REQUIRED — generated nextflow.config path; fail if exists

    vep_cache_ver        = '115'

    /* =============== SKIP FLAGS ===============
       Set skip_X = true to suppress that asset's download. The generated
       nextflow.config will omit the corresponding param(s) with a comment;
       the user wires those paths in manually.
    */
    skip_ref_fasta       = false
    skip_vep_cache       = false
    skip_alphamissense   = false
    skip_revel           = false   // forced true if url_revel is null (PLACEHOLDER)
    skip_utr_annotator   = false
    skip_gnomad          = false
    skip_cadd            = false   // covers both SNV + indel
    skip_clinvar         = false
    skip_svafotate       = false
    skip_ref_gene        = false
    skip_somalier        = false
    skip_igv_ideogram    = false

    /* =============== URLS ===============
       Override any of these to repoint or repair a broken default.
    */
    url_ref_fasta_base   = 'https://storage.googleapis.com/gcp-public-data--broad-references/hg38/v0'
    url_vep_cache        = 'https://ftp.ensembl.org/pub/release-115/variation/indexed_vep_cache/homo_sapiens_vep_115_GRCh38.tar.gz'
    url_alphamissense    = 'https://storage.googleapis.com/dm_alphamissense/AlphaMissense_hg38.tsv.gz'
    url_revel            = 'https://zenodo.org/records/7072866/files/revel-v1.3_all_chromosomes.zip?download=1'
    url_utr_annotator    = 'https://raw.githubusercontent.com/ImperialCardioGenetics/UTRannotator/master/uORF_5UTR_GRCh38_PUBLIC.txt'
    url_gnomad_pattern   = 'https://storage.googleapis.com/gcp-public-data--gnomad/release/4.1/vcf/joint/gnomad.joint.v4.1.sites.chr<CHR>.vcf.bgz'
    gnomad_chrs          = (1..22).collect{ it.toString() } + ['X', 'Y']
    url_cadd_snv         = 'https://kircherlab.bihealth.org/download/CADD/v1.7/GRCh38/whole_genome_SNVs.tsv.gz'
    url_cadd_indel       = 'https://kircherlab.bihealth.org/download/CADD/v1.7/GRCh38/gnomad.genomes.r4.0.indel.tsv.gz'
    url_clinvar          = 'https://ftp.ncbi.nlm.nih.gov/pub/clinvar/vcf_GRCh38/'   // dir; latest clinvar_<YYYYMMDD>.vcf.gz selected
    url_svafotate        = 'https://zenodo.org/records/11642574/files/SVAFotate_core_SV_popAFs.GRCh38.v4.1.bed.gz?download=1'
    url_ref_gene         = 'https://hgdownload.soe.ucsc.edu/goldenPath/hg38/database/ncbiRefSeqSelect.txt.gz'
    url_somalier_sites           = 'https://github.com/brentp/somalier/files/3412456/sites.hg38.vcf.gz'
    url_somalier_ancestry_labels = 'https://raw.githubusercontent.com/brentp/somalier/master/scripts/ancestry-labels-1kg.tsv'
    url_somalier_1kg             = 'https://zenodo.org/record/3479773/files/1kg.somalier.tar.gz?download=1'
    url_igv_ideogram             = 'https://hgdownload.soe.ucsc.edu/goldenPath/hg38/database/cytoBandIdeo.txt.gz'
}

includeConfig '../profiles.config'

profiles {
    apptainer  { 
        apptainer.enabled  = true
        apptainer.autoMounts  = true 
        docker.enabled = false 
        singularity.enabled = false
    }
    singularity{ 
        singularity.enabled = true
        singularity.autoMounts = true 
        apptainer.enabled  = false
        docker.enabled = false 
    }
    docker     { 
        docker.enabled = true 
        singularity.enabled = false
        apptainer.enabled  = false
    }
}

process {
    shell = ['/bin/bash', '-euo', 'pipefail']
    errorStrategy = { task.attempt <= 3 ? 'retry' : 'finish' }
    maxRetries = 3

    withLabel: bcftools {
        container = 'quay.io/biocontainers/bcftools:1.21--h3a4d415_1'
    }

    withLabel: C2M2T24 {
        cpus   = 2
        memory = { 2 * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 24 * (2 ** (task.attempt - 1)) + ' h' }
    }
    withLabel: C2M4T24 {
        cpus   = 2
        memory = { 4 * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 24 * (2 ** (task.attempt - 1)) + ' h' }
    }
    withLabel: C2M16T24 {
        cpus   = 2
        memory = { 16 * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 24 * (2 ** (task.attempt - 1)) + ' h' }
    }
}
